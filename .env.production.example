# =========================
# Production Env Template
# =========================

# Public app URL (replace with your real domain)
NEXT_PUBLIC_APP_URL=https://gptimageprompt.xyz

# -------------------------
# Clerk Auth
# -------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_xxx
CLERK_SECRET_KEY=sk_live_xxx

# -------------------------
# Supabase
# -------------------------
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role...

# Storage buckets (keep defaults unless changed in Supabase)
SUPABASE_PROMPT_IMAGES_BUCKET=prompt-template-images
SUPABASE_GENERATED_IMAGES_BUCKET=generated-images

# -------------------------
# Image Generation Provider
# -------------------------
# OpenAI-compatible endpoint for GPT Image 2
OPENAI_BASE_URL=https://hk-api.gptbest.vip
OPENAI_API_KEY=sk-xxx
OPENAI_IMAGE_TIMEOUT_MS=180000

# -------------------------
# Payments (Creem)
# -------------------------
CREEM_API_KEY=creem_live_xxx
# Optional in your current minimal flow (kept for future webhook support)
CREEM_WEBHOOK_SECRET=

# -------------------------
# Access Control
# -------------------------
# Comma-separated admin emails for template creation/import
ADMIN_EMAILS=denghuichao90@gmail.com

# -------------------------
# API Cache
# -------------------------
PROMPTS_API_CACHE_TTL_MS=30000
PROMPTS_API_CACHE_MAX_ENTRIES=500

# -------------------------
# Legacy / optional (not required by current core flow)
# -------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=
